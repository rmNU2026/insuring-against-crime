e_rate=('first_time', 'mean'),\n","    alcohol_share=('ALCFLG', 'mean'),\n","    heroin_share=('HERFLG', 'mean'),\n","    marijuana_share=('MARFLG', 'mean'),\n","    cocaine_share=('COKEFLG', 'mean'),\n","    meth_share=('MTHAMFLG', 'mean'),\n","    opioid_share=('OPSYNFLG', 'mean'),\n",").reset_index()\n","\n","count_agg = count_agg.rename(columns={'STFIPS': 'state', 'AGE': 'age_bracket'})\n","count_agg['period'] = '2006-2018'\n","\n","print(f\"Aggregated: {count_agg.shape}\")\n","count_agg.to_csv(save_dir + \"teds_2006_2018_agg_expanded.csv\", index=False)\n","del df; gc.collect()\n","print(\"Done.\")"],"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"uvA9Z2QZA25l","executionInfo":{"status":"ok","timestamp":1772925378334,"user_tz":360,"elapsed":97799,"user":{"displayName":"Roman Modhera","userId":"15741868874131970637"}},"outputId":"56524a7e-1350-45e7-975c-9a8a05b0fe96"},"execution_count":null,"outputs":[{"output_type":"stream","name":"stdout","text":["Loaded: (15701236, 39)\n","After filter: 2,797,674 rows\n","Aggregated: (498, 28)\n","Done.\n"]}]},{"cell_type":"code","source":["import pandas as pd\n","import numpy as np\n","import statsmodels.formula.api as smf\n","import warnings\n","warnings.filterwarnings(\"ignore\")\n","\n","save_dir = \"/content/drive/MyDrive/Colab Notebooks/Thesis/Data/Mechanisms Data /(Substance Mental Health)TEDS-A/\"\n","\n","# Load aggregated files\n","df1 = pd.read_csv(save_dir + \"teds_1992_1999_agg_expanded.csv\")\n","df2 = pd.read_csv(save_dir + \"teds_2000_2002_agg_expanded.csv\")\n","df3 = pd.read_csv(save_dir + \"teds_2003_2005_agg_expanded.csv\")\n","df4 = pd.read_csv(save_dir + \"teds_2006_2018_agg_expanded.csv\")\n","\n","df_all = pd.concat([df1, df2, df3, df4], ignore_index=True)\n","print(f\"Combined: {df_all.shape}\")\n","\n","# Create windows\n","df_adolescent = df_all[df_all['age_bracket'].isin([1, 2])].copy()\n","df_young_adult = df_all[df_all['age_bracket'].isin([3, 4])].copy()\n","df_adult = df_all[df_all['age_bracket'].isin([5, 6])].copy()\n","\n","for name, d in [('Adolescent', df_adolescent), ('Young Adult', df_young_adult), ('Adult', df_adult)]:\n","    print(f\"{name}: {len(d)} cells, {d['total_admissions'].sum():,} admissions\")\n","\n","# Merge eligibility\n","elig_path = \"/content/drive/MyDrive/Colab Notebooks/Thesis/Data/[Final]_US_Crime_Rates_1999_2010.csv\"\n","df_elig = pd.read_csv(elig_path).rename(columns={'fips': 'state', 'brthyr': 'birth_year'})\n","elig_cols = ['state', 'birth_year', 'cumulative_eligibility', 'elig_0_5', 'elig_6_11',\n","             'elig_12_18', 'Childhood_Avg_Unemployment', 'childhood_avg_income']\n","elig_xwalk = df_elig[elig_cols].drop_duplicates(subset=['state', 'birth_year'])\n","elig_xwalk['log_childhood_income'] = np.log(elig_xwalk['childhood_avg_income'].clip(lower=1))\n","\n","for name in ['df_adolescent', 'df_young_adult', 'df_adult']:\n","    d = eval(name)\n","    d['state'] = d['state'].astype(int)\n","    d['birth_year'] = d['birth_year'].astype(int)\n","    merged = pd.merge(d, elig_xwalk, on=['state', 'birth_year'], how='left')\n","    exec(f\"{name} = merged\")\n","\n","# Cumulative-to-date for adolescent\n","age_mp = {1: 13, 2: 16}\n","df_adolescent['age_midpoint'] = df_adolescent['age_bracket'].map(age_mp)\n","def cum_to_date(row):\n","    mp = row['age_midpoint']\n","    if pd.isna(row['elig_0_5']): return np.nan\n","    return row['elig_0_5'] + row['elig_6_11'] + (row['elig_12_18'] / 7) * (mp - 11)\n","df_adolescent['cum_elig_to_date'] = df_adolescent.apply(cum_to_date, axis=1)\n","\n","# === RUN REGRESSIONS ===\n","def add_stars(p):\n","    if pd.isna(p): return ''\n","    if p < 0.01: return '***'\n","    if p < 0.05: return '**'\n","    if p < 0.1: return '*'\n","    return ''\n","\n","# Expanded outcome list\n","share_outcomes = ['medicaid_share', 'selfpay_share', 'insured_share',\n","                  'first_time_rate', 'psych_comorbid_rate', 'cj_referral_rate',\n","                  'alcohol_share', 'heroin_share', 'marijuana_share',\n","                  'cocaine_share', 'meth_share', 'opioid_share']\n","\n","# Count outcomes — use log(count+1) for better distribution\n","count_outcomes = ['total_admissions', 'medicaid_admissions', 'first_time_admissions',\n","                  'heroin_admissions', 'marijuana_admissions', 'opioid_admissions',\n","                  'alcohol_admissions', 'cj_admissions']\n","\n","all_results = []\n","\n","windows = [\n","    ('Adolescent (12-17)', df_adolescent, ['cum_elig_to_date', 'elig_0_5', 'elig_6_11', 'elig_12_18']),\n","    ('Young Adult (18-24)', df_young_adult, ['cumulative_eligibility', 'elig_0_5', 'elig_6_11', 'elig_12_18']),\n","    ('Adult (25-34)', df_adult, ['cumulative_eligibility', 'elig_0_5', 'elig_6_11', 'elig_12_18']),\n","]\n","\n","for window_name, df_w, elig_vars in windows:\n","    df_reg = df_w.dropna(subset=['cumulative_eligibility'] if 'cumulative_eligibility' in df_w.columns else ['cum_elig_to_date']).reset_index(drop=True)\n","\n","    # Create log count outcomes\n","    for c in count_outcomes:\n","        if c in df_reg.columns:\n","            df_reg[f'log_{c}'] = np.log(df_reg[c] + 1)\n","\n","    log_count_outcomes = [f'log_{c}' for c in count_outcomes if f'log_{c}' in df_reg.columns]\n","    all_outcomes = [o for o in share_outcomes + log_count_outcomes if o in df_reg.columns]\n","\n","    print(f\"\\n{window_name}: {len(df_reg)} cells, outcomes: {len(all_outcomes)}\")\n","\n","    for outcome in all_outcomes:\n","        if df_reg[outcome].notna().sum() < 30: continue\n","\n","        for elig in elig_vars:\n","            if elig not in df_reg.columns: continue\n","\n","            # Weight by total_admissions for share outcomes, unweighted for log counts\n","            use_weights = outcome in share_outcomes\n","\n","            formula = (f'{outcome} ~ {elig} + Childhood_Avg_Unemployment + log_childhood_income'\n","                       f' + birth_year + C(state) + C(age_bracket)')\n","\n","            data = df_reg[[outcome, elig, 'Childhood_Avg_Unemployment', 'log_childhood_income',\n","                            'birth_year', 'state', 'age_bracket', 'total_admissions']].dropna().reset_index(drop=True)\n","            if len(data) < 30: continue\n","\n","            try:\n","                if use_weights:\n","                    model = smf.wls(formula=formula, data=data, weights=data['total_admissions'])\n","                else:\n","                    model = smf.wls(formula=formula, data=data, weights=data['total_admissions'])\n","\n","                res = model.fit(cov_type='cluster', cov_kwds={'groups': data['state']})\n","\n","                all_results.append({\n","                    'Window': window_name, 'Outcome': outcome, 'Eligibility': elig,\n","                    'Coefficient': res.params[elig], 'Std Error': res.bse[elig],\n","                    'P-value': res.pvalues[elig], 'R-squared': res.rsquared,\n","                    'N_cells': int(res.nobs), 'Total_admissions': int(data['total_admissions'].sum())\n","                })\n","            except Exception as e:\n","                print(f\"  Error {window_name} {outcome}~{elig}: {e}\")\n","\n","results_df = pd.DataFrame(all_results)\n","\n","if not results_df.empty:\n","    results_df['Formatted'] = results_df.apply(\n","        lambda r: f\"{r['Coefficient']:.4f}{add_stars(r['P-value'])} ({r['Std Error']:.4f})\", axis=1)\n","\n","    for window in ['Adolescent (12-17)', 'Young Adult (18-24)', 'Adult (25-34)']:\n","        subset = results_df[results_df['Window'] == window]\n","        if subset.empty: continue\n","\n","        pivot = subset.pivot(index='Outcome', columns='Eligibility', values='Formatted')\n","\n","        print(f\"\\n{'='*80}\")\n","        print(f\"TEDS-A EXPANDED RESULTS — {window}\")\n","        print(f\"{'='*80}\")\n","        display(pivot)\n","\n","    results_df.to_csv(save_dir + \"teds_expanded_regression_results.csv\", index=False)\n","    prin