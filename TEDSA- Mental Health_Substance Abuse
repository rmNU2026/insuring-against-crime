'] == 1).astype(float))\n","df['any_insurance'] = np.where(df['PRIMPAY'].isna(), np.nan, df['PRIMPAY'].isin([2,3,4,5]).astype(float))\n","\n","# Psychiatric comorbidity\n","if 'PSYPROB' in df.columns:\n","    df['psych_comorbid'] = np.nan\n","    df.loc[df['PSYPROB'] == 1, 'psych_comorbid'] = 1\n","    df.loc[df['PSYPROB'] == 2, 'psych_comorbid'] = 0\n","\n","# Criminal justice\n","if 'DETCRIM' in df.columns:\n","    df['cj_referral'] = np.nan\n","    df.loc[df['DETCRIM'] == 1, 'cj_referral'] = 1\n","    df.loc[df['DETCRIM'] == 2, 'cj_referral'] = 0\n","\n","# === NEW: Substance-specific flags (already binary 0/1) ===\n","substance_flags = ['ALCFLG', 'HERFLG', 'MARFLG', 'COKEFLG', 'MTHAMFLG', 'OPSYNFLG']\n","for flag in substance_flags:\n","    if flag in df.columns:\n","        df[flag] = df[flag].replace(-9, np.nan)\n","\n","# === NEW: First-time treatment seeker ===\n","# NOPRIOR coding: 0=No prior, 1=One prior, 2=Two prior, 3=Three prior, 4=Four+, -9=Missing\n","if 'NOPRIOR' in df.columns:\n","    df['first_time'] = np.nan\n","    df.loc[df['NOPRIOR'] == 0, 'first_time'] = 1  # No prior episodes\n","    df.loc[df['NOPRIOR'] > 0, 'first_time'] = 0   # Has prior episodes\n","\n","# === NEW: Has health insurance ===\n","# HLTHINS coding varies by year but generally: 1=Private, 2=Medicaid, 3=Medicare,\n","# 4=Other, -9=Missing/Unknown. Check actual values:\n","if 'HLTHINS' in df.columns:\n","    print(f\"\\nHLTHINS value counts:\\n{df['HLTHINS'].value_counts().sort_index()}\")\n","\n","# === AGGREGATE ===\n","agg_dict = {'PRIMPAY': 'count'}  # total admissions\n","\n","# Share-based outcomes (means)\n","share_vars = ['medicaid_payer', 'self_pay', 'any_insurance', 'psych_comorbid',\n","              'cj_referral', 'first_time']\n","for v in share_vars:\n","    if v in df.columns and df[v].notna().any():\n","        agg_dict[v] = 'mean'\n","\n","# Substance flag means (= share of admissions involving each substance)\n","for flag in substance_flags:\n","    if flag in df.columns and df[flag].notna().any():\n","        agg_dict[flag] = 'mean'\n","\n","# Count-based outcomes (sums — for utilization rates)\n","count_vars = {}\n","for flag in substance_flags:\n","    if flag in df.columns:\n","        count_vars[f'{flag}_count'] = flag\n","\n","# For counts, we need a separate aggregation\n","df_agg = df.groupby(['STFIPS', 'birth_year', 'AGE']).agg(agg_dict).reset_index()\n","\n","# Add count-based outcomes\n","count_agg = df.groupby(['STFIPS', 'birth_year', 'AGE']).agg(\n","    total_admissions=('PRIMPAY', 'count'),\n","    alcohol_admissions=('ALCFLG', lambda x: (x == 1).sum()),\n","    heroin_admissions=('HERFLG', lambda x: (x == 1).sum()),\n","    marijuana_admissions=('MARFLG', lambda x: (x == 1).sum()),\n","    cocaine_admissions=('COKEFLG', lambda x: (x == 1).sum()),\n","    meth_admissions=('MTHAMFLG', lambda x: (x == 1).sum()),\n","    opioid_admissions=('OPSYNFLG', lambda x: (x == 1).sum()),\n","    cj_admissions=('DETCRIM', lambda x: (x == 1).sum()) if 'DETCRIM' in df.columns else ('PRIMPAY', lambda x: np.nan),\n","    first_time_admissions=('first_time', lambda x: (x == 1).sum()) if 'first_time' in df.columns else ('PRIMPAY', lambda x: np.nan),\n","    medicaid_admissions=('medicaid_payer', lambda x: (x == 1).sum()),\n",").reset_index()\n","\n","# Merge share and count aggregations\n","df_agg = pd.merge(\n","    df_agg.rename(columns={'STFIPS': 'state', 'AGE': 'age_bracket', 'PRIMPAY': 'total_admissions'}),\n","    count_agg.rename(columns={'STFIPS': 'state', 'AGE': 'age_bracket'}).drop(columns=['total_admissions']),\n","    on=['state', 'birth_year', 'age_bracket'],\n","    how='left'\n",")\n","\n","# Rename share vars\n","rename_shares = {\n","    'medicaid_payer': 'medicaid_share', 'self_pay': 'selfpay_share',\n","    'any_insurance': 'insured_share', 'psych_comorbid': 'psych_comorbid_rate',\n","    'cj_referral': 'cj_referral_rate', 'first_time': 'first_time_rate',\n","    'ALCFLG': 'alcohol_share', 'HERFLG': 'heroin_share', 'MARFLG': 'marijuana_share',\n","    'COKEFLG': 'cocaine_share', 'MTHAMFLG': 'meth_share', 'OPSYNFLG': 'opioid_share',\n","}\n","df_agg = df_agg.rename(columns={k:v for k,v in rename_shares.items() if k in df_agg.columns})\n","\n","df_agg['period'] = '1992-1999'\n","\n","print(f\"\\nAggregated: {df_agg.shape}\")\n","print(f\"Columns: {sorted(df_agg.columns.tolist())}\")\n","print(f\"Mean total admissions per cell: {df_agg['total_admissions'].mean():.0f}\")\n","print(f\"Mean first_time_rate: {df_agg['first_time_rate'].mean():.3f}\" if 'first_time_rate' in df_agg.columns else \"\")\n","\n","df_agg.to_csv(save_dir + \"teds_1992_1999_agg_expanded.csv\", index=False)\n","del df; gc.collect()\n","print(\"Done.\")"],"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"qAYMrDY3AozD","executionInfo":{"status":"ok","timestamp":1772925262450,"user_tz":360,"elapsed":4129,"user":{"displayName":"Roman Modhera","userId":"15741868874131970637"}},"outputId":"9d4edcba-58d7-4ee4-db85-934ab737cb3b"},"execution_count":null,"outputs":[{"output_type":"stream","name":"stdout","text":["Loaded: (960098, 37)\n","After cohort + state filter: 77,100 rows\n","\n","HLTHINS value counts:\n","HLTHINS\n","1.0     7407\n","2.0     8749\n","3.0     3224\n","4.0    16116\n","Name: count, dtype: int64\n","\n","Aggregated: (146, 26)\n","Columns: ['age_bracket', 'alcohol_admissions', 'alcohol_share', 'birth_year', 'cj_admissions', 'cj_referral_rate', 'cocaine_admissions', 'cocaine_share', 'first_time_admissions', 'first_time_rate', 'heroin_admissions', 'heroin_share', 'insured_share', 'marijuana_admissions', 'marijuana_share', 'medicaid_admissions', 'medicaid_share', 'meth_admissions', 'meth_share', 'opioid_admissions', 'opioid_share', 'period', 'psych_comorbid_rate', 'selfpay_share', 'state', 'total_admissions']\n","Mean total admissions per cell: 182\n","Mean first_time_rate: 0.734\n","Done.\n"]}]},{"cell_type":"code","metadata":{"colab":{"base_uri":"https://localhost:8080/","height":1000},"id":"04c1d0e4","executionInfo":{"status":"ok","timestamp":1772926265798,"user_tz":360,"elapsed":6257,"user":{"displayName":"Roman Modhera","userId":"15741868874131970637"}},"outputId":"5ace15d9-62f8-4563-c0b3-8a2e86342b52"},"source":["import pandas as pd\n","import numpy as np\n","import statsmodels.formula.api as smf\n","import warnings\n","warnings.filterwarnings(\"ignore\")\n","\n","save_dir = \"/content/drive/MyDrive/Colab Notebooks/Thesis/Data/Mechanisms Data /(Substance Mental Health)TEDS-A/\"\n","\n","# Load aggregated files\n","df1 = pd.read_csv(save_dir + \"teds_1992_1999_agg_expanded.csv\")\n","df2 = pd.read_csv(save_dir + \"teds_2000_2002_agg_expanded.csv\")\n","df3 = pd.read_csv(save_dir + \"teds_2003_2005_agg_expanded.csv\")\n","df4 = pd.read_csv(save_dir + \"teds_2006_2018_agg_expanded.csv\")\n","\n","df_all = pd.concat([df1, df2, df3, df4], ignore_index=True)\n","print(f\"Combined: {df_all.shape}\")\n","\n","# Create windows\n","df_adolescent = df_all[df_all['age_bracket'].isin([1, 2])].copy()\n","df_young_adult = df_all[df_all['age_bracket'].isin([3, 4])].copy()\n","df_adult = df_all[df_all['age_bracket'].isin([5, 6])].copy()\n","\n","for name, d in [('Adolescent', df_adolescent), ('Young Adult', df_young_adult), ('Adult', df_adult)]:\n","    print(f\"{name}: {len(d)} cells, {d['total_admissions'].sum():,} admissions\")\n","\n","# Merge eligibility\n","elig_path = \"/content/drive/MyDrive/Colab Notebooks/Thesis/Data/[Final]_US_Crime_Rates_1999_2010.csv\"\n","df_elig = pd.read_csv(elig_path).rename(columns={'fips': 'state', 'brthyr': 'birth_year'})\n","elig_cols = ['state', 'birth_year', 'cumulative_eligibility', 'elig_0_5', 'elig_6_11',\n","             'elig_12_18', 'Childhood_Avg_Unemployment', 'childhood_avg_income']\n","elig_xwalk = df_elig[elig_cols].copy().drop_duplicates(subset=['state', 'birth_year'])\n","elig_xwalk['log_childhood_income'] = np.log(elig_xwalk['childhood_avg_income'].clip(lower=1))\n","\n","for name in ['df_adolescent', 'df_young_adult', 'df_adult']:\n","    d = eval(name)\n","    d['state'] = d['state'].astype(int)\n","    d['birth_year'] = d['birth_year'].astype(int)\n","    merged = pd.merge(d, elig_xwalk, on=['state', 'birth_year'], how='left')\n","    exec(f\"{name} = merged\")\n","\n","# === Add cumulative-to-date eligibility for all windows using annual lookup ===\n","# Load annual cumulative eligibility (exact values from BKL calculator)\n","df_annual = pd.read_csv(\"/content/drive/MyDrive/df_cumulative_annual_eligibility.csv\")\n","age_midpoints_map = {1: 13, 2: 16, 3: 19, 4: 22, 5: 27, 6: 32}\n","\n","for name_str, df_w in [('df_adolescent', df_adolescent),\n","                        ('df_young_adult', df_young_adult),\n","                        ('df_adult', df_adult)]:\n","    df_w['age_midpoint'] = df_w['age_bracket'].map(age_midpoints_map)\n","\n","    # Age >= 19: all childhood eligibility complete\n","    adult_mask = df_w['age_midpoint'] >= 19\n","    df_w.loc[adult_mask, 'cum_elig_to_date'] = df_w.loc[adult_mask, 'cumulative_eligibility']\n","\n","    # Age < 19: look up exact value from annual data\n","    for idx in df_w[~adult_mask].index:\n","        state = int(df_w.loc[idx, 'state'])\n","        by = int(df_w.loc[idx, 'birth_year'])\n","        mp = int(df_w.loc[idx, 'age_midpoint'])\n","        lookup = df_annual[\n","            (df_annual['STATEFIP'] == state) &\n","            (df_annual['birth_year'] == by) &\n","            (df_annual['age_child'] == mp)\n","        ]\n","        if len(lookup) > 0:\n","            df_w.loc[idx, 'cum_elig_to_date'] = lookup.iloc[0]['cumulative_eligibility_to_date']\n","        else:\n","            df_w.loc[idx, 'cum_elig_to_date'] = np.nan\n","\n","    if name_str == 'df_adolescent': df_adolescent = df_w\n","    elif name_str == 'df_young_adult': df_young_adult = df_w\n","    else: df_adult = df_w\n","\n","print(\"\\nAdolescent cum_elig_to_date by bracket:\")\n","print(df_adolescent.groupby('age_bracket')[['cum_elig_to_date', 'cumulative_eligibility']].mean())\n","\n","# === RUN REGRESSIONS ===\n","def add_stars(p):\n","    if pd.isna(p): return ''\n","    if p < 0.01: return '***'\n","    if p < 0.05: return '**'\n","    if p < 0.1: return '*'\n","    return ''\n","\n","# Expanded outcome list\n","share_outcomes = ['medicaid_share', 'selfpay_share', 'insured_share',\n","                  'first_time_rate', 'psych_comorbid_rate', 'cj_referral_rate',\n","                  'alcohol_share', 'heroin_share', 'marijuana_share',\n","                  'cocaine_share', 'meth_share', 'opioid_share']\n","\n","# Count outcomes — use log(count+1) for better distribution\n","count_outcomes = ['total_admissions', 'medicaid_admissions', 'first_time_admissions',\n","                  'heroin_admissions', 'marijuana_admissions', 'opioid_admissions',\n","                  'alcohol_admissions', 'cj_admissions']\n","\n","all_results = []\n","\n","windows = [\n","    ('Adolescent (12-17)', df_adolescent, ['cum_elig_to_date', 'elig_0_5', 'elig_6_11', 'elig_12_18']),\n","    ('Young Adult (18-24)', df_young_adult, ['cumulative_eligibility', 'elig_0_5', 'elig_6_11', 'elig_12_18']),\n","    ('Adult (25-34)', df_adult, ['cumulative_eligibility', 'elig_0_5', 'elig_6_11', 'elig_12_18']),\n","]\n","\n","for window_name, df_w, elig_vars in windows:\n","    df_reg = df_w.dropna(subset=['cumulative_eligibility'] if 'cumulative_eligibility' in df_w.columns else ['cum_elig_to_date']).reset_index(drop=True)\n","\n","    # Create log count outcomes\n","    for c in count_outcomes:\n","        if c in df_reg.columns:\n","            df_reg[f'log_{c}'] = np.log(df_reg[c] + 1)\n","\n","    log_count_outcomes = [f'log_{c}' for c in count_outcomes if f'log_{c}' in df_reg.columns]\n","    all_outcomes = [o for o in share_outcomes + log_count_outcomes if o in df_reg.columns]\n","\n","    print(f\"\\n{window_name}: {len(df_reg)} cells, outcomes: {len(all_outcomes)}\")\n","\n","    for outcome in all_outcomes:\n","        if df_reg[outcome].notna().sum() < 30: continue\n","\n","        for elig in elig_vars:\n","            if elig not in df_reg.columns: continue\n","\n","            # Weight by total_admissions for share outcomes, unweighted for log counts\n","            use_weights = outcome in share_outcomes\n","\n","            formula = (f'{outcome} ~ {elig} + Childhood_Avg_Unemployment + log_childhood_income'\n","                       f' + birth_year + C(state) + C(age_bracket)')\n","\n","            data = df_reg[[outcome, elig, 'Childhood_Avg_Unemployment', 'log_childhood_income',\n","                            'birth_year', 'state', 'age_bracket', 'total_admissions']].dropna().reset_index(drop=True)\n","            if len(data) < 30: continue\n","\n","            try:\n","                if use_weights:\n","                    model = smf.wls(formula=formula, data=data, weights=data['total_admissions'])\n","                else:\n","                    model = smf.wls(formula=formula, data=data, weights=data['total_admissions'])\n","\n","                res = model.fit(cov_type='cluster', cov_kwds={'groups': data['state']})\n","\n","                all_results.append({\n","                    'Window': window_name, 'Outcome': outcome, 'Eligibility': elig,\n","                    'Coefficient': res.params[elig], 'Std Error': res.bse[elig],\n","                    'P-value': res.pvalues[elig], 'R-squared': res.rsquared,\n","                    'N_cells': int(res.nobs), 'Total_admissions': int(data['total_admissions'].sum())\n","                })\n","            except Exception as e:\n","                print(f\"  Error {window_name} {outcome}~{elig}: {e}\")\n","\n","results_df = pd.DataFrame(all_results)\n","\n","if not results_df.empty:\n","    results_df['Formatted'] = results_df.apply(\n","        lambda r: f\"{r['Coefficient']:.4f}{add_stars(r['P-value'])} ({r['Std Error']:.4f})\", axis=1)\n","\n","    for window in ['Adolescent (12-17)', 'Young Adult (18-24)', 'Adult (25-34)']:\n","        subset = results_df[results_df['Window'] == window]\n","        if subset.empty: continue\n","\n","        pivot = subset.pivot(index='Outcome', columns='Eligibility', values='Formatted')\n","\n","        print(f\"\\n{'='*80}\")\n","        print(f\"TEDS-A EXPANDED RESULTS — {window}\")\n","        print(f\"{'='*80}\")\n","        display(pivot)\n","\n","    results_df.to_csv(save_dir + \"teds_expanded_regression_results.csv\", index=False)\n","    print(\"\\nResults saved.\")\n","else:\n","    print(\"No results.\")\n","\n","gc.collect()\n","print(\"Done running regressions.\")\n"],"execution_count":null,"outputs":[{"output_type":"stream","name":"stdout","text":["Combined: (993, 28)\n","Adolescent: 196 cells, 66,882 admissions\n","Young Adult: 349 cells, 412,931 admissions\n","Adult: 398 cells, 830,196 admissions\n","\n","Adolescent cum_elig_to_date by bracket:\n","             cum_elig_to_date  cumulative_eligibility\n","age_bracket                                          \n","2.0                  3.710224                4.608382\n","\n","Adolescent (12-17): 192 cells, outcomes: 20\n","\n","Young Adult (18-24): 342 cells, outcomes: 20\n","\n","Adult (25-34): 390 cells, outcomes: 20\n","\n","================================================================================\n","TEDS-A EXPANDED RESULTS — Adolescent (12-17)\n","================================================================================\n"]},{"output_type":"display_data","data":{"text/plain":["Eligibility                  cum_elig_to_date          elig_0_5  \\\n","Outcome                                                           \n","alcohol_share                -0.0343 (0.0335)   0.1623 (0.2976)   \n","cj_referral_rate            0.0000** (0.0000)   0.0000 (0.0000)   \n","cocaine_share               0.0136** (0.0055)   0.0145 (0.0294)   \n","first_time_rate               0.0378 (0.0293)   0.2560 (0.2376)   \n","heroin_share                  0.0122 (0.0074)   0.0002 (0.029