_merged)} rows, \"\n","          f\"matched: {n_matched}/{len(df_w_merged)} ({n_matched/len(df_w_merged)*100:.1f}%)\")\n","\n","    if name == 'Adolescent': df_adolescent = df_w_merged\n","    elif name == 'Young Adult': df_young_adult = df_w_merged\n","    else: df_adult = df_w_merged\n","\n","# === Add cumulative-to-date eligibility for all windows using annual lookup ===\n","# Load annual cumulative eligibility (exact values from BKL calculator)\n","df_annual = pd.read_csv(\"/content/drive/MyDrive/df_cumulative_annual_eligibility.csv\")\n","age_midpoints_map = {1: 13, 2: 16, 3: 19, 4: 22, 5: 27, 6: 32}\n","\n","for name_str, df_w in [('df_adolescent', df_adolescent),\n","                        ('df_young_adult', df_young_adult),\n","                        ('df_adult', df_adult)]:\n","    df_w['age_midpoint'] = df_w['age_bracket'].map(age_midpoints_map)\n","\n","    # Age >= 19: all childhood eligibility complete\n","    adult_mask = df_w['age_midpoint'] >= 19\n","    df_w.loc[adult_mask, 'cum_elig_to_date'] = df_w.loc[adult_mask, 'cumulative_eligibility']\n","\n","    # Age < 19: look up exact value from annual data\n","    for idx in df_w[~adult_mask].index:\n","        state = int(df_w.loc[idx, 'state'])\n","        by = int(df_w.loc[idx, 'birth_year'])\n","        mp = int(df_w.loc[idx, 'age_midpoint'])\n","        lookup = df_annual[\n","            (df_annual['STATEFIP'] == state) &\n","            (df_annual['birth_year'] == by) &\n","            (df_annual['age_child'] == mp)\n","        ]\n","        if len(lookup) > 0:\n","            df_w.loc[idx, 'cum_elig_to_date'] = lookup.iloc[0]['cumulative_eligibility_to_date']\n","        else:\n","            df_w.loc[idx, 'cum_elig_to_date'] = np.nan\n","\n","    if name_str == 'df_adolescent': df_adolescent = df_w\n","    elif name_str == 'df_young_adult': df_young_adult = df_w\n","    else: df_adult = df_w\n","\n","print(\"\\nAdolescent cum_elig_to_date by bracket:\")\n","print(df_adolescent.groupby('age_bracket')[['cum_elig_to_date', 'cumulative_eligibility']].mean())\n","\n","# Verify eligibility increases across cohorts\n","for name, df_w in [('Adolescent', df_adolescent), ('Young Adult', df_young_adult), ('Adult', df_adult)]:\n","    print(f\"\\n{name} — mean cumulative_eligibility by birth_year:\")\n","    print(df_w.groupby('birth_year')['cumulative_eligibility'].mean())\n","\n","# Save all three windows\n","df_adolescent.to_csv(save_dir + \"teds_window_adolescent.csv\", index=False)\n","df_young_adult.to_csv(save_dir + \"teds_window_young_adult.csv\", index=False)\n","df_adult.to_csv(save_dir + \"teds_window_adult.csv\", index=False)\n","print(\"\\nAll three windows saved.\")"],"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"9o9s7zI4_lW9","executionInfo":{"status":"ok","timestamp":1772926259178,"user_tz":360,"elapsed":346,"user":{"displayName":"Roman Modhera","userId":"15741868874131970637"}},"outputId":"ca55d3da-5959-45cd-d1be-79f9897d6d52"},"execution_count":null,"outputs":[{"output_type":"stream","name":"stdout","text":["1992-1999: (146, 10), brackets: [np.float64(2.0)], states: 50, total admissions: 26,524\n","2000-2002: (201, 10), brackets: [np.float64(2.0), np.float64(3.0)], states: 51, total admissions: 166,659\n","2003-2005: (148, 10), brackets: [np.float64(3.0), np.float64(4.0)], states: 51, total admissions: 202,470\n","2006-2018: (498, 12), brackets: [np.int64(4), np.int64(5), np.int64(6), np.int64(7)], states: 51, total admissions: 1,040,304\n","\n","Combined: (993, 12)\n","\n","Adolescent window (12-17): 196 cells, 66,882 admissions\n","Young adult window (18-24): 349 cells, 412,931 admissions\n","Adult window (25-34): 398 cells, 830,196 admissions\n","\n","Eligibility crosswalk: (200, 9)\n","\n","Adolescent: 196 -> 196 rows, matched: 192/196 (98.0%)\n","\n","Young Adult: 349 -> 349 rows, matched: 342/349 (98.0%)\n","\n","Adult: 398 -> 398 rows, matched: 390/398 (98.0%)\n","\n","Adolescent cum_elig_to_date by bracket:\n","         