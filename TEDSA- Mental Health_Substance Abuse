oid_share',\n","    'cj_referral_rate', 'first_time_rate', 'insured_share', 'psych_comorbid_rate',\n","    'private_share', 'nocharge_share'\n","]\n","\n","# Log count outcomes:\n","log_count_outcomes_initial = [\n","    'log_total', 'log_medicaid', 'log_heroin', 'log_marijuana',\n","    'log_opioid', 'log_alcohol', 'log_cj', 'log_first_time',\n","    'log_psych_comorbid', 'log_selfpay', 'log_insured', 'log_private', 'log_nocharge'\n","]\n","\n","# Only include outcomes that exist in the DataFrame.\n","share_outcomes = [o for o in share_outcomes_initial if o in df.columns]\n","log_count_outcomes = [o for o in log_count_outcomes_initial if o in df.columns]\n","all_outcomes = share_outcomes + log_count_outcomes\n","\n","print(f\"\\nShare Outcomes used: {share_outcomes}\")\n","print(f\"Log Count Outcomes used: {log_count_outcomes}\")\n","\n","# Eligibility variables:\n","eligibility_vars = ['cum_elig_to_date', 'elig_0_5', 'elig_6_11', 'elig_12_18']\n","\n","def add_stars(p):\n","    if pd.isna(p): return ''\n","    if p < 0.01: return '***'\n","    if p < 0.05: return '**'\n","    if p < 0.1: return '*'\n","    return ''\n","\n","all_results = []\n","\n","# --- POOLED REGRESSIONS (all brackets, with C(age_bracket) FE) ---\n","print(\"\\nRunning POOLED regressions...\")\n","pooled_base_formula_parts = ' + Childhood_Avg_Unemployment + log_childhood_income + admyr + C(state) + C(age_bracket)'\n","pooled_data_cols_base = ['Childhood_Avg_Unemployment', 'log_childhood_income', 'admyr', 'state', 'age_bracket']\n","\n","for outcome in all_outcomes:\n","    for elig in eligibility_vars:\n","        pooled_formula = f'{outcome} ~ {elig}' + pooled_base_formula_parts\n","\n","        # WLS\n","        wls_pooled_data_cols = [outcome, elig, 'total_admissions'] + pooled_data_cols_base\n","        wls_pooled_data = df[wls_pooled_data_cols].dropna().reset_index(drop=True)\n","        wls_pooled_data = wls_pooled_data[wls_pooled_data['total_admissions'] > 0].copy().reset_index(drop=True)\n","        if len(wls_pooled_data) >= 20:\n","            try:\n","                wls_model = smf.wls(formula=pooled_formula, data=wls_pooled_data, weights=wls_pooled_data['total_admissions'])\n","                wls_res = wls_model.fit(cov_type='cluster', cov_kwds={'groups': wls_pooled_data['state']})\n","                all_results.append({\n","                    'RegressionType': 'WLS', 'Specification': 'Pooled', 'Outcome': outcome, 'Eligibility': elig,\n","                    'Coefficient': wls_res.params[elig], 'Std_Error': wls_res.bse[elig], 'P_value': wls_res.pvalues[elig],\n","                    'R_squared': wls_res.rsquared, 'N_cells': int(wls_res.nobs)\n","                })\n","            except Exception as e:\n","                # print(f\"Error in Pooled WLS {outcome} ~ {elig}: {e}\")\n","                pass # Suppress minor errors in non-critical regressions\n","\n","        # OLS\n","        ols_pooled_data_cols = [outcome, elig] + pooled_data_cols_base\n","        ols_pooled_data = df[ols_pooled_data_cols].dropna().reset_index(drop=True)\n","        if len(ols_pooled_data) >= 20:\n","            try:\n","                ols_model = smf.ols(formula=pooled_formula, data=ols_pooled_data)\n","                ols_res = ols_model.fit(cov_type='cluster', cov_kwds={'groups': ols_pooled_data['state']})\n","                all_results.append({\n","                    'RegressionType': 'OLS', 'Specification': 'Pooled', 'Outcome': outcome, 'Eligibility': elig,\n","                    'Coefficient': ols_res.params[elig], 'Std_Error': ols_res.bse[elig], 'P_value': ols_res.pvalues[elig],\n","                    'R_squared': ols_res.rsquared, 'N_cells': int(ols_res.nobs)\n","                })\n","            except Exception as e:\n","                # print(f\"Error in Pooled OLS {outcome} ~ {elig}: {e}\")\n","                pass # Suppress minor errors in non-critical regressions\n","\n","# --- WITHIN-BRACKET REGRESSIONS ---\n","print(\"\\nRunning WITHIN-BRACKET regressions...\")\n","for bracket_val in sorted(df['age_bracket'].unique()):\n","    df_bracket = df[df['age_bracket'] == bracket_val].copy()\n","    spec_name = f'Bracket_{int(bracket_val)}'\n","\n","    num_unique_admyr = df_bracket['admyr'].nunique()\n","    if num_unique_admyr > 1:\n","        bracket_base_formula_parts = ' + Childhood_Avg_Unemployment + log_childhood_income + admyr + C(state)'\n","        bracket_data_cols_base = ['Childhood_Avg_Unemployment', 'log_childhood_income', 'admyr', 'state']\n","    else: # num_unique_admyr == 1 (e.g., bracket 4 has only 2005)\n","        bracket_base_formula_parts = ' + Childhood_Avg_Unemployment + log_childhood_income + C(state)'\n","        bracket_data_cols_base = ['Childhood_Avg_Unemployment', 'log_childhood_income', 'state']\n","\n","    for outcome in all_outcomes:\n","        for elig in eligibility_vars:\n","            bracket_formula = f'{outcome} ~ {elig}' + bracket_base_formula_parts\n","\n","            # WLS\n","            wls_bracket_data_cols = [outcome, elig, 'total_admissions'] + bracket_data_cols_base\n","            wls_bracket_data = df_bracket[wls_bracket_data_cols].dropna().reset_index(drop=True)\n","            wls_bracket_data = wls_bracket_data[wls_bracket_data['total_admissions'] > 0].copy().reset_index(drop=True)\n","            if len(wls_bracket_data) >= 20:\n","                try:\n","                    wls_model = smf.wls(formula=bracket_formula, data=wls_bracket_data, weights=wls_bracket_data['total_admissions'])\n","                    wls_res = wls_model.fit(cov_type='cluster', cov_kwds={'groups': wls_bracket_data['state']})\n","                    all_results.append({\n","                        'RegressionType': 'WLS', 'Specification': spec_name, 'Outcome': outcome, 'Eligibility': elig,\n","                        'Coefficient': wls_res.params[elig], 'Std_Error': wls_res.bse[elig], 'P_value': wls_res.pvalues[elig],\n","                        'R_squared': wls_res.rsquared, 'N_cells': int(wls_res.nobs)\n","                    })\n","                except Exception as e:\n","                    # print(f\"Error in {spec_name} WLS {outcome} ~ {elig}: {e}\")\n","                    pass\n","\n","            # OLS\n","            ols_bracket_data_cols = [outcome, elig] + bracket_data_cols_base\n","            ols_bracket_data = df_bracket[ols_bracket_data_cols].dropna().reset_index(drop=True)\n","            if len(ols_bracket_data) >= 20:\n","                try:\n","                    ols_model = smf.ols(formula=bracket_formula, data=ols_bracket_data)\n","                    ols_res = ols_model.fit(cov_type='cluster', cov_kwds={'groups': ols_bracket_data['state']})\n","                    all_results.append({\n","                        'RegressionType': 'OLS', 'Specification': spec_name, 'Outcome': outcome, 'Eligibility': elig,\n","                        'Coefficient': ols_res.params[elig], 'Std_Error': ols_res.bse[elig], 'P_value': ols_res.pvalues[elig],\n","                        'R_squared': ols_res.rsquared, 'N_cells': int(ols_res.nobs)\n","                    })\n","                except Exception as e:\n","                    # print(f\"Error in {spec_name} OLS {outcome} ~ {elig}: {e}\")\n","                    pass\n","\n","# 1. Create results DataFrame\n","results_df = pd.DataFrame(all_results)\n","\n","# 2. Add Formatted column\n","if not results_df.empty:\n","    results_df['Formatted'] = results_df.apply(\n","        lambda r: f\"{r['Coefficient']:.4f}{add_stars(r['P_value'])} ({r['Std_Error']:.4f})\", axis=1)\n","\n","    # 3. Display POOLED WLS results as primary table:\n","    print(f\"\\n{'='*80}\")\n","    print(f\"POOLED STATE-YEAR TEDS-A RESULTS (All Brackets, Ages 12-24)\")\n","    print(f\"Treatment = average eligibility-to-date across cohorts in each bracket-year\")\n","    print(f\"WLS weighted by total_admissions, clustered SE by state\")\n","    print(f\"FE: C(state), C(age_bracket). Controls: Childhood_Avg_Unemployment, log_childhood_income, admyr\")\n","    print(f\"{'='*80}\")\n","\n","    wls_pooled_pivot = results_df[\n","        (results_df['RegressionType'] == 'WLS') &\n","        (results_df['Specification'] == 'Pooled') &\n","        (results_df['Eligibility'].isin(['cum_elig_to_date', 'elig_0_5', 'elig_6_11', 'elig_12_18']))\n","    ].pivot(index='Outcome', columns='Eligibility', values='Formatted')\n","\n","    display(wls_pooled_pivot)\n","\n","    # 4. Display BY-BRACKET WLS results for cum_elig_to_date only:\n","    print(f\"\\n{'='*80}\")\n","    print(\"BY-BRACKET WLS RESULTS for cum_elig_to_date\")\n","    print(f\"WLS weighted by total_admissions, clustered SE by state. Controls + FE as per bracket\")\n","    print(f\"{'='*80}\")\n","\n","    by_bracket_wls_pivot = results_df[\n","        (results_df['RegressionType'] == 'WLS') &\n","        (results_df['Eligibility'] == 'cum_elig_to_date') &\n","        results_df['Specification'].str.startswith('Bracket')\n","    ].pivot(index='Outcome', columns='Specification', values='Formatted')\n","\n","    display(by_bracket_wls_pivot)\n","\n","    # 5. Display ROBUSTNESS comparison for cum_elig_to_date pooled:\n","    print(f\"\\n{'='*80}\")\n","    print(\"ROBUSTNESS: POOLED WLS vs OLS comparison for cum_elig_to_date\")\n","    print(f\"{'='*80}\")\n","\n","    robustness_pooled_pivot = results_df[\n","        (results_df['RegressionType'] == 'WLS') &\n","        (results_df['Specification'] == 'Pooled') &\n","        (results_df['Eligibility'] == 'cum_elig_to_date')\n","    ].pivot(index='Outcome', columns='RegressionType', values='Formatted')\n","\n","    display(robustness_pooled_pivot)\n","\n","    # 6. Print SUMMARY of all significant results (p < 0.10) sorted by P_value\n","    print(f\"\\n{'='*80}\")\n","    print(\"SUMMARY OF SIGNIFICANT RESULTS (p < 0.10) - All Regressions\")\n","    print(f\"{'='*80}\")\n","    significant_results = results_df[results_df['P_value'] < 0.10].sort_values(by='P_value')\n","    if not significant_results.empty:\n","        print(significant_results[['Specification', 'Outcome', 'Eligibility', 'RegressionType', 'Coefficient', 'P_value']].to_markdown(index=False))\n","    else:\n","        print(\"No significant results found (p < 0.10).\")\n","\n","    # 7. Save results\n","    results_df.to_csv(save_dir + \"teds_state_year_bracket_results.csv\", index=False)\n","    print(f\"\\nAll regression results saved to {save_dir}teds_state_year_bracket_results.csv\")\n","else:\n","    print(\"No regression results to display or save.\")\n","\n","gc.collect()\n","print(\"Done running regressions.\")\n","\n"],"execution_count":null,"outputs":[{"output_type":"stream","name":"stdout","text":["Loaded: (249, 56)\n","\n","Share Outcomes used: ['medicaid_share', 'selfpay_share', 'alcohol_share', 'heroin_share', 'marijuana_share', 'cocaine_share', 'meth_share', 'opioid_share', 'cj_referral_rate', 'first_time_rate', 'insured_share', 'psych_comorbid_rate', 'private_share', 'nocharge_share']\n","Log Count Outcomes used: ['log_total', 'log_medicaid', 'log_heroin', 'log_marijuana', 'log_opioid', 'log_alcohol', 'log_cj', 'log_first_time', 'log_psych_comorbid', 'log_selfpay', 'log_insured', 'log_private', 'log_nocharge']\n","\n","Running POOLED regressions...\n","\n","Running WITHIN-BRACKET regressions...\n","\n","================================================================================\n","POOLED STATE-YEAR TEDS-A RESULTS (All Brackets, Ages 12-24)\n","Treatment = average eligibility-to-date across cohorts in each bracket-year\n","WLS weighted by total_admissions, clustered SE by state\n","FE: C(state), C(age_bracket). Controls: Childhood_Avg_Unemployment, log_childhood_income, admyr\n","================================================================================\n"]},{"output_type":"display_data","data":{"text/plain":["Eligibility            cum_elig_to_date          elig_0_5         elig_12_18  \\\n","Outcome                             