0.0092)\",\n          \"-0.0230 (0.0285)\"\n        ],\n        \"semantic_type\": \"\",\n        \"description\": \"\"\n      }\n    }\n  ]\n}"}},"metadata":{}},{"output_type":"stream","name":"stdout","text":["\n","Results saved.\n","Done running regressions.\n"]}]},{"cell_type":"code","metadata":{"colab":{"base_uri":"https://localhost:8080/","height":1000},"id":"f3c0cbde","executionInfo":{"status":"ok","timestamp":1772926350920,"user_tz":360,"elapsed":3168,"user":{"displayName":"Roman Modhera","userId":"15741868874131970637"}},"outputId":"bec11f20-c8c4-46b3-aaee-96d7c6a6f6a5"},"source":["import pandas as pd\n","import numpy as np\n","import statsmodels.formula.api as smf\n","import warnings\n","warnings.filterwarnings(\"ignore\")\n","\n","save_dir = \"/content/drive/MyDrive/Colab Notebooks/Thesis/Data/Mechanisms Data /(Substance Mental Health)TEDS-A/\"\n","\n","# Load windows\n","df_adolescent = pd.read_csv(save_dir + \"teds_window_adolescent.csv\")\n","df_young_adult = pd.read_csv(save_dir + \"teds_window_young_adult.csv\")\n","df_adult = pd.read_csv(save_dir + \"teds_window_adult.csv\")\n","\n","def add_stars(p):\n","    if pd.isna(p): return ''\n","    if p < 0.01: return '***'\n","    if p < 0.05: return '**'\n","    if p < 0.1: return '*'\n","    return ''\n","\n","# Common outcomes across all windows\n","common_outcomes = ['medicaid_share', 'selfpay_share', 'insured_share',\n","                   'psych_comorbid_rate', 'cj_referral_rate']\n","\n","all_results = []\n","\n","# === ADOLESCENT WINDOW ===\n","# Primary treatment: cum_elig_to_date (varies by bracket)\n","# Also test window-specific variables\n","adol_elig_vars = ['cum_elig_to_date', 'elig_0_5', 'elig_6_11', 'elig_12_18']\n","df_reg = df_adolescent.dropna(subset=['cumulative_eligibility']).reset_index(drop=True)\n","print(f\"Adolescent: {len(df_reg)} cells, {df_reg['state'].nunique()} states, \"\n","      f\"{df_reg['total_admissions'].sum():,} admissions\")\n","\n","for outcome in common_outcomes:\n","    if outcome not in df_reg.columns: continue\n","    if df_reg[outcome].notna().sum() < 30: continue\n","\n","    for elig in adol_elig_vars:\n","        if elig not in df_reg.columns: continue\n","\n","        formula = (f'{outcome} ~ {elig} + Childhood_Avg_Unemployment + log_childhood_income'\n","                   f' + birth_year + C(state) + C(age_bracket)')\n","\n","        data = df_reg[[outcome, elig, 'Childhood_Avg_Unemployment', 'log_childhood_income',\n","                        'birth_year', 'state', 'age_bracket', 'total_admissions']].dropna().reset_index(drop=True)\n","        if len(data) < 30: continue\n","\n","        try:\n","            model = smf.wls(formula=formula, data=data, weights=data['total_admissions'])\n","            res = model.fit(cov_type='cluster', cov_kwds={'groups': data['state']})\n","            all_results.append({\n","                'Window': 'Adolescent (12-17)',\n","                'Outcome': outcome, 'Eligibility': elig,\n","                'Coefficient': res.params[elig], 'Std Error': res.bse[elig],\n","                'P-value': res.pvalues[elig], 'R-squared': res.rsquared,\n","                'N_cells': int(res.nobs), 'Total_admissions': int(data['total_admissions'].sum())\n","            })\n","        except Exception as e:\n","            print(f\"  Error Adolescent {outcome}~{elig}: {e}\")\n","\n","# === YOUNG ADULT WINDOW ===\n","ya_elig_vars = ['cumulative_eligibility', 'elig_0_5', 'elig_6_11', 'elig_12_18']\n","ya_outcomes = common_outcomes + [c for c in ['private_share', 'nocharge_share'] if c in df_young_adult.columns]\n","df_reg = df_young_adult.dropna(subset=['cumulative_eligibility']).reset_index(drop=True)\n","print(f\"\\nYoung Adult: {len(df_reg)} cells, {df_reg['state'].nunique()} states, \"\n","      f\"{df_reg['total_admissions'].sum():,} admissions\")\n","\n","for outcome in ya_outcomes:\n","    if outcome not in df_reg.columns: continue\n","    if df_reg[outcome].notna().sum() < 30: continue\n"