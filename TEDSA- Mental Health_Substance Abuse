et]\n","    ratio = sub['cum_elig_to_date'].mean() / sub['cumulative_eligibility'].mean()\n","    print(f\"  Bracket {bracket} (midpoint {bracket_midpoints[bracket]}): \"\n","          f\"mean cum_to_date={sub['cum_elig_to_date'].mean():.3f}, \"\n","          f\"mean cumulative={sub['cumulative_eligibility'].mean():.3f}, \"\n","          f\"ratio={ratio:.3f}\")\n","\n","# Bracket 1 ratio should be ~0.6 (ages 0-13 out of 0-18)\n","# Bracket 2 ratio should be ~0.85 (ages 0-16 out of 0-18)\n","# Brackets 3-4 ratio should be 1.0\n","\n","print(\"\\nSample — Alabama across all bracket-years:\")\n","print(df_avg_elig[df_avg_elig['state'] == 1][\n","    ['state', 'age_bracket', 'admyr', 'cohorts', 'bracket_midpoint',\n","     'cum_elig_to_date', 'cumulative_eligibility']\n","].to_string(index=False))\n","\n","# === STEP 6: Merge with admissions counts and create outcomes ===\n","df_counts = pd.read_csv(save_dir + \"teds_state_year_bracket_counts.csv\")\n","df_counts['state'] = df_counts['state'].astype(int)\n","df_counts['age_bracket'] = df_counts['age_bracket'].astype(int)\n","\n","df_analysis = pd.merge(df_counts, df_avg_elig, on=['state', 'admyr', 'age_bracket'], how='left')\n","n_matched = df_analysis['cumulative_eligibility'].notna().sum()\n","print(f\"\\nMerged: {len(df_analysis)} rows, matched {n_matched}/{len(df_analysis)}\")\n","\n","# Create share outcomes\n","df_analysis['medicaid_share'] = df_analysis['medicaid_count'] / df_analysis['total_admissions']\n","df_analysis['selfpay_share'] = df_analysis['selfpay_count'] / df_analysis['total_admissions']\n","for sub in ['alcohol', 'heroin', 'marijuana', 'cocaine', 'meth', 'opioid']:\n","    col = f'{sub}_count'\n","    if col in df_analysis.columns:\n","        df_analysis[f'{sub}_share'] = df_analysis[col] / df_analysis['total_admissions']\n","if 'cj_count' in df_analysis.columns:\n","    df_analysis['cj_referral_rate'] = df_analysis['cj_count'] / df_analysis['total_admissions']\n","if 'first_time_count' in df_analysis.columns:\n","    df_analysis['first_time_rate'] = df_analysis['first_time_count'] / df_analysis['total_admissions']\n","if 'psych_comorbid_count' in df_analysis.columns:\n","    df_analysis['psych_comorbid_rate'] = df_analysis['psych_comorbid_count'] / df_analysis['total_admissions']\n","if 'insured_count' in df_analysis.columns:\n","    df_analysis['insured_share'] = df_analysis['insured_count'] / df_analysis['total_admissions']\n","if 'private_count' in df_analysis.columns:\n","    df_analysis['private_share'] = df_analysis['private_count'] / df_analysis['total_admissions']\n","if 'nocharge_count' in df_analysis.columns:\n","    df_analysis['nocharge_share'] = df_analysis['nocharge_count'] / df_analysis['total_admissions']\n","\n","# Create log count outcomes\n","df_analysis['log_total'] = np.log(df_analysis['total_admissions'] + 1)\n","for sub in ['medicaid', 'heroin', 'marijuana', 'opioid', 'alcohol', 'cj',\n","            'first_time', 'psych_comorbid', 'selfpay', 'insured', 'private', 'nocharge']:\n","    col = f'{sub}_count'\n","    if col in df_analysis.columns:\n","        df_analysis[f'log_{sub}'] = np.log(df_analysis[col] + 1)\n","\n","# Verify shares\n","print(\"\\nShare means (all should be 0-1):\")\n","for c in [c for c in df_analysis.columns if '_share' in c or c.endswith('_rate')]:\n","    mn = df_analysis[c].mean()\n","    mx = df_analysis[c].max()\n","    status = \"OK\" if mx <= 1.001 else \"ERROR\"\n","    print(f\"  {c}: mean={mn:.4f}, max={mx:.4f} {status}\")\n","\n","# Window labels\n","df_analysis['window'] = df_analysis['age_bracket'].map({\n","    1: 'Adolescent (12-14)', 2: 'Adolescent (15-17)',\n","    3: 'Young Adult (18-20)', 4: 'Young Adult (21-24)'\n","})\n","print(f\"\\nCells per window:\\n{df_analysis['window'].value_counts().sort_index().to_markdown()}\")\n","\n","# Save\n","df_analysis.to_csv(save_dir + \"teds_state_year_analysis.csv\", index=False)\n","print(f\"\\nSaved: {df_analysis.shape}\")\n","gc.collect()"],"execution_count":null,"outputs":[{"output_type":"stream","name":"stdout","text":["Annual eligibility data: (3876, 5)\n","Columns: ['STATEFIP', 'birth_year', 'age_child', 'sim_eligfpl', 'cumulative_eligibility_to_date']\n","Sample:\n","|   STATEFIP |   birth_year |   age_child |   sim_eligfpl |   cumulative_eligibility_to_date |\n","|-----------:|-------------:|------------:|--------------:|---------------------------------:|\n","|          1 |         1981 |           0 |      0.177416 |                         0.177416 |\n","|          1 |         1981 |           1 |      0.181689 |                         0.359105 |\n","|          1 |         1981 |           2 |      0.18131  |                         0.540415 |\n","|          1 |         1981 |           3 |      0.176968 |                         0.717383 |\n","|          1 |         1981 |           4 |      0.138957 |                         0.85634  |\n","|          1 |         1981 |           5 |      0.144    |                         1.00034  |\n","|          1 |         1981 |           6 |      0.138991 |                         1.13933  |\n","|          1 |         1981 |           7 |      0.12333  |                         1.26266  |\n","|          1 |         1981 |           8 |      0.13542  |                         1.39808  |\n","|          1 |         1981 |           9 |      0.144936 |                         1.54302  |\n","\n","Unique ages: [np.int64(0), np.int64(1), np.int64(2), np.int64(3), np.int64(4), np.int64(5), np.int64(6), np.int64(7), np.int64(8), np.int64(9), np.int64(10), np.int64(11), np.int64(12), np.int64(13), np.int64(14), np.int64(15), np.int64(16), np.int64(17), np.int64(18)]\n","Unique birth_years: [np.int64(1981), np.int64(1982), np.int64(1983), np.int64(1984)]\n","Unique states: 51\n","\n","Eligibility crosswalk: (200, 9)\n","\n","Average eligibility data: (354, 13)\n","\n","Verification — cum_elig_to_date vs cumulative_eligibility by bracket:\n","  Bracket 1 (midpoint 13): mean cu